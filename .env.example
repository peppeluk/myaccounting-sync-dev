# Firebase Configuration Template
# Copia questo file in .env e inserisci i tuoi dati Firebase

# Firebase Realtime Database Configuration
VITE_FIREBASE_API_KEY=la-tua-api-key
VITE_FIREBASE_AUTH_DOMAIN=tuo-progetto.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://tuo-progetto-default-rtdb.firebaseio.com/
VITE_FIREBASE_PROJECT_ID=tuo-progetto-id
VITE_FIREBASE_STORAGE_BUCKET=tuo-progetto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456
